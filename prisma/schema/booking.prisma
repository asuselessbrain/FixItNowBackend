enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Bookings {
  id           String             @id @default(uuid())
  customerId   String
  customer     User               @relation(fields: [customerId], references: [id])
  
  serviceId    String
  service      Service            @relation(fields: [serviceId], references: [id])
  
  technicianId String
  technician   TechnicianProfiles @relation(fields: [technicianId], references: [id])

  slotId       String             @unique
  slot         TechnicianSlots    @relation(fields: [slotId], references: [id], onDelete: Restrict)

  totalAmount  Float
  status       BookingStatus      @default(PENDING)
  
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([customerId])
  @@index([technicianId])
  @@map("bookings")
}