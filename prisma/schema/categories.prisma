model Categories {
    id          String   @id @default(uuid())
    name        String   @db.VarChar(50)
    description String?
    slug        String   @unique @db.VarChar(50)
    image_url   String?
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([slug], name: "slug_index")
    @@map("categories")
}
